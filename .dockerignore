# Version control
.git
.gitignore

# Dev dependencies / local state
node_modules
npm-debug.log*

# Next.js build artifacts (rebuilt in Docker)
.next/
out/

# Environment files — NEVER bake into image
.env
.env.*
!.env.example

# Local document storage
storage/

# Terraform state / secrets
infrastructure/**/.terraform
infrastructure/**/terraform.tfstate*
infrastructure/**/*.tfvars
!infrastructure/**/*.tfvars.example

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage/
*.test.ts
*.spec.ts
__tests__/

# CI/CD artifacts
.github/
