# =============================================================================
# Lincoln - Law Firm Case Management Platform
# Environment Configuration
# =============================================================================
# SECURITY: Never commit .env to version control.
# Copy this file to .env.local for local development.

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/lincoln_dev?schema=public"

# --- Authentication ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-64-char-random-string"
# Application base URL
AUTH_URL="http://localhost:3000"

# Session max age in seconds (default: 8 hours for HIPAA compliance)
SESSION_MAX_AGE=28800

# --- Encryption ---
# Master key for envelope encryption. Generate with: openssl rand -hex 32
# CRITICAL: Rotate this key only with a proper key rotation procedure.
MASTER_ENCRYPTION_KEY="replace-with-64-hex-char-random-key"

# Salt for HKDF key derivation (per-tenant key derivation)
ENCRYPTION_SALT="replace-with-32-hex-char-random-salt"

# --- Document Storage ---
# Options: "local" | "s3"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage/documents"

# S3-compatible storage (required if STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""
# AWS_S3_ENDPOINT="" # For non-AWS S3 (e.g., MinIO)

# --- Application ---
APP_NAME="Lincoln"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Maximum file upload size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png,text/plain"

# --- Rate Limiting ---
# Max login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=30

# --- Audit Log Retention ---
# Days to retain audit logs (HIPAA minimum: 6 years)
AUDIT_LOG_RETENTION_DAYS=2190
