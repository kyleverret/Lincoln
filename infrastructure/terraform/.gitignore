# Terraform state — use S3 backend, never commit locally
.terraform/
terraform.tfstate
terraform.tfstate.backup
.terraform.lock.hcl

# Variables with secrets
terraform.tfvars
*.tfvars
!*.tfvars.example

# Plans (can contain sensitive values)
*.tfplan
tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log
